# --- CAN PICORNELL ENVIRONMENT CONFIGURATION ---

# Base URL of the website (must end with a slash)
BASE_URL=https://canpicornell.com/

# Owner email to receive reservation request notifications
CONTACT_EMAIL=info@canpicornell.com

# --- DATABASE CONFIGURATION ---
# Options: 'sqlite' or 'mysql'
DB_DRIVER=sqlite
DB_PATH=api/database.sqlite

# Optional MySQL configuration (only used if DB_DRIVER=mysql)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=canpicornell_db
MYSQL_USER=db_user
MYSQL_PASSWORD=db_password

# --- STRIPE GATEWAY CREDENTIALS ---
# Replace with Stripe Sandbox keys for testing, and Live keys for production
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# --- SMTP MAIL SERVER CONFIGURATION (OPTIONAL) ---
# If left blank, the system will fall back to native PHP mail()
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME="Can Picornell"
SMTP_FROM_EMAIL=info@canpicornell.com
